<Window x:Class="MyControlApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Control Hub" Height="520" Width="360"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True" ShowInTaskbar="False"
        ResizeMode="NoResize" Visibility="Hidden">

    <Window.Resources>

        <!-- Modern flat slider (Windows 11 style) -->
        <Style x:Key="ModernSlider" TargetType="Slider">
            <Setter Property="Height" Value="24"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Border Height="6" CornerRadius="3" Background="#2a2a3d"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Border Height="6" CornerRadius="3">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#7f5af0" Offset="0"/>
                                                            <GradientStop Color="#2cb67d" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="18" Height="18">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="White">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="10" Color="#7f5af0" Opacity="0.7" ShadowDepth="0"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Flat modern button -->
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon-only close/hide button -->
        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a0a0b8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

    </Window.Resources>

    <Border Background="#16161f" CornerRadius="18" BorderBrush="#2a2a3d" BorderThickness="1.2">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.6" ShadowDepth="4" Direction="270"/>
        </Border.Effect>

        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar (drag + close) -->
            <DockPanel Grid.Row="0" Margin="0,0,0,22" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="#7f5af0" Margin="0,0,8,0"/>
                    <TextBlock Text="Control Hub" Foreground="White" FontSize="17" FontWeight="SemiBold"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="✕" Click="Hide_Click" Style="{StaticResource IconButton}" HorizontalAlignment="Right"/>
            </DockPanel>

            <StackPanel Grid.Row="1">

                <!-- Brightness -->
                <Border Background="#1e1e2b" CornerRadius="12" Padding="16,14" Margin="0,0,0,14">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="💡  Brightness" Foreground="#e0e0f0" FontSize="13" FontWeight="Medium"/>
                            <TextBlock x:Name="BrightnessValueText" Text="80%" Foreground="#7f5af0" FontSize="13" FontWeight="Bold" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Slider x:Name="BrightnessSlider" Style="{StaticResource ModernSlider}"
                                Minimum="10" Maximum="100" Value="80"
                                ValueChanged="BrightnessSlider_ValueChanged"/>
                    </StackPanel>
                </Border>

                <!-- Volume -->
                <Border Background="#1e1e2b" CornerRadius="12" Padding="16,14" Margin="0,0,0,14">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="🔊  Volume" Foreground="#e0e0f0" FontSize="13" FontWeight="Medium"/>
                            <TextBlock x:Name="VolumeValueText" Text="50%" Foreground="#2cb67d" FontSize="13" FontWeight="Bold" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <Slider x:Name="VolumeSlider" Style="{StaticResource ModernSlider}"
                                Minimum="0" Maximum="100" Value="50"
                                ValueChanged="VolumeSlider_ValueChanged"/>
                    </StackPanel>
                </Border>

                <!-- Screenshot -->
                <Button Content="📸  Take Screenshot" Click="TakeScreenshot_Click"
                        Style="{StaticResource FlatButton}" Background="#7f5af0" Foreground="White"
                        FontWeight="SemiBold" FontSize="13" Margin="0,0,0,14" Height="42"/>

                <!-- Hotkey settings -->
                <Border Background="#1e1e2b" CornerRadius="12" Padding="16,14">
                    <StackPanel>
                        <TextBlock Text="⌨  Overlay Hotkey" Foreground="#e0e0f0" FontSize="13" FontWeight="Medium" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#2a2a3d" CornerRadius="8" Padding="10,8" Margin="0,0,8,0">
                                <TextBlock x:Name="HotkeyDisplayText" Text="Win + Shift + C" Foreground="#7f5af0" FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <Button x:Name="ChangeHotkeyButton" Grid.Column="1" Content="Change"
                                    Click="ChangeHotkey_Click" Style="{StaticResource FlatButton}"
                                    Background="#2a2a3d" Foreground="#e0e0f0" FontSize="12" Padding="14,8"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>

            <TextBlock Grid.Row="2" x:Name="FooterHintText" Text="Press Win + Shift + C to toggle this panel"
                       Foreground="#565672" FontSize="11" HorizontalAlignment="Center" Margin="0,18,0,0"/>
        </Grid>
    </Border>
</Window>
